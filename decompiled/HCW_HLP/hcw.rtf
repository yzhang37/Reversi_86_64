{\up +}{\footnote\pard\plain{\up +} BROWSE0027:0158}
{\up $}{\footnote\pard\plain{\up $} ScanTopicText function}
{\up #}{\footnote\pard\plain{\up #} 1NK4.UJ}
\pard\keepn\sb115\sa115\sl-235\li115\ri125 {\up A}{\footnote\pard\plain{\up A} FTS_Index_Construct;ScanTopicText}
{\up K}{\footnote\pard\plain{\up K} ScanTopicText function}
\b\fs24 ScanTopicText
\par \pard\sb75\sl-235\li115\ri125 \plain\f1\fs16 ERRORCODE ScanTopicText(HINDEX hinx, PBYTE pbText, UINT cbText, UINT iCharset, UINT lcid);
\par Adds information about the words or phrases in *pbText to the given index, associating them with the current topic.
\par \pard\sb75\sl-235\li1435\ri125\fi-1305\brdrb\brdrs\tx1435 \b Parameter\tab Description\plain\f1\fs16 
\par \pard\sb55\sl-235\li1435\ri125\fi-1305\tx1435 hinx\tab Handle of an index. Must have been previously created using the \b NewIndex\plain\f1\fs16  function.
\par pbText\tab Address of the buffer containing the text to scan. The text can be any combination of words and punctuation.
\par cbText\tab Size in bytes of the text to scan.
\par iCharset\tab Character set of the text to scan. If this parameter is USE_DEFAULT, the function uses the default character set specified when the index was created.
\par lcid\tab Locale identifier of the text to scan. If this parameter is USE_DEFAULT, the function uses the default locale specified when the index was created.
\par \pard\sb115\sl-235\li115\ri125\tx1435 \b Return Value
\par \pard\sb75\sl-235\li115\ri125\tx1435 \plain\f1\fs16 Returns 0 if successful; an error value otherwise.
\par \pard\sl-115\li265\ri125\fi-185\brdrb\brdrs\tx295 
\par \pard\sb45\sl-235\li295\ri125\fi-185\tx295 \{button ,AL("ScanTopicTitle;NewIndex;fts_errorcode")\} \uldb Related Topics\plain\f1\fs16 {\v %!AL("ScanTopicTitle;NewIndex;fts_errorcode")}
