\par \f2 \'b7\f1 \tab \uldb \'5cemspace\plain\f1\fs16 {\v 1X9ISO4>tables}
\par \f2 \'b7\f1 \tab \uldb \'5censpace\plain\f1\fs16 {\v GLD2DA>tables}
\par \f2 \'b7\f1 \tab \uldb \'5clquote\plain\f1\fs16 {\v D2X9GS>tables}
\par \f2 \'b7\f1 \tab \uldb \'5crquote\plain\f1\fs16 {\v _.DCI4>tables}
