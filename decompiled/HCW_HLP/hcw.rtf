\par \page
{\up +}{\footnote\pard\plain{\up +} BROWSE0027:0157}
{\up $}{\footnote\pard\plain{\up $} ScanText function}
{\up #}{\footnote\pard\plain{\up #} 0BEWMY}
\pard\keepn\sb115\sa115\sl-235\li115\ri125 {\up A}{\footnote\pard\plain{\up A} FTS_phrase_compress;ScanText}
{\up K}{\footnote\pard\plain{\up K} ScanText function}
\b\fs24 ScanText
\par \pard\sb75\sl-235\li115\ri125 \plain\f1\fs16 ERRORCODE ScanText(HCOMPRESSOR hcmp, PBYTE pbText, UINT cbText, UINT iCharset);
\par Scans the given text to gather statistics about word usage. Those statistics are used to generate the phrase table returned by \b GetPhraseTable\plain\f1\fs16  and used by \b CompressText\plain\f1\fs16  and \b DecompressText\plain\f1\fs16 .
\par \pard\sb75\sl-235\li1435\ri125\fi-1305\brdrb\brdrs\tx1435 \b Parameter\tab Description\plain\f1\fs16 
\par \pard\sb55\sl-235\li1435\ri125\fi-1305\tx1435 hcmp\tab Handle of the compressor. Must have been previously created using the \b NewCompressor\plain\f1\fs16  function.
\par pbText\tab Address of the buffer containing the text to be scanned.
\par cbText\tab Size in bytes of the text.
\par iCharset\tab Character set of the text to be compressed. If this parameter is USE_DEFAULT, the function uses the default character set specified when the compressor was created.
\par \pard\sb115\sl-235\li115\ri125\tx1435 \b Return Value
\par \pard\sb75\sl-235\li115\ri125\tx1435 \plain\f1\fs16 Returns 0 if successful; an error value otherwise.
\par \pard\sl-115\li265\ri125\fi-185\brdrb\brdrs\tx295 
\par \pard\sb45\sl-235\li295\ri125\fi-185\tx295 \{button ,AL("fts_errorcode;GetPhraseTable;CompressText;DecompressText;NewCompressor")\} \uldb Related Topics\plain\f1\fs16 {\v %!AL("fts_errorcode;GetPhraseTable;CompressText;DecompressText;NewCompressor")}
