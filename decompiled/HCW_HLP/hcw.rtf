\par \pard\sb75\sl-235\li295\ri125\fi-185\tx1075 \plain\f1\fs16 \{bmc bm1.bmp\}\tab bullet.bmp
\par \pard\sb45\sl-235\li295\ri125\fi-185\tx1075 \{bmc bm2.bmp\}\tab emdash.bmp
\par \{bmct bm3.bmp\}\tab shortcut.bmp
