\par \pard\sb75\sl-235\li115\ri125 Re-enables a menu item that was disabled by using the DisableItem or ExtAbleItem macro.
\par \pard\sb75\sl-235\li1575\ri125\fi-1455\brdrb\brdrs\tx1575 \b Parameter\tab Description\plain\f1\fs16 
