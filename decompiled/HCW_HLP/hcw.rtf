\b To enable ALink and KLink jumps to other Help files
\par \pard\sb45\sl-235\li295\ri125\fi-185\tx295 \plain\f1\fs16 1\tab In Help Workshop, open the contents (.cnt) file.
\par 2\tab Click the Link Files button.
\par 3\tab Click Add, and then type the name of the Help file that you want to search when an \ul ALink\plain\f1\fs16 {\v 7V8V.U} or \ul KLink\plain\f1\fs16 {\v 7V8V.U} macro is run.
\par \pard\sb115\sl-235\li115\ri125\tx295 \b Note
\par \pard\sb75\sl-235\li295\ri125\fi-185\tx295 \plain\f2\fs16 \'b7\tab \f1 You do not need add files that have already been included in the Index Files dialog box.
\par \pard\sl-115\li265\ri125\fi-185\brdrb\brdrs\tx295 
\par \pard\sb45\sl-235\li295\ri125\fi-185\tx295 \{button ,AL(`BAS_CNT_OVERVIEW;BAS_CNT_COMBINE_HLP_FILES')\} \uldb Related Topics\plain\f1\fs16 {\v %!AL(`BAS_CNT_OVERVIEW;BAS_CNT_COMBINE_HLP_FILES')}
