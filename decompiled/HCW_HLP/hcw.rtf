{\up #}{\footnote\pard\plain{\up #} PRO_CNT_DYN}
\pard\sb115\sa35\sl-235\li115\ri125 {\up A}{\footnote\pard\plain{\up A} PRO_CNT;PRO_CNT_DYN}
