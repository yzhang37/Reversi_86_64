/* Included by reversi.rc. Menu and strings for pt-PT. */

LANGUAGE LANG_PORTUGUESE, SUBLANG_PORTUGUESE
IDR_MAINMENU MENU
BEGIN
    POPUP "&Jogo"
    BEGIN
        MENUITEM "&Novo\tF2", IDM_NEW
        MENUITEM SEPARATOR
        MENUITEM "&Passar", IDM_PASS
        MENUITEM "&Sugestão\tBackspace", IDM_HINT
        MENUITEM SEPARATOR
        MENUITEM "&Sair", IDM_EXIT
    END
    POPUP "&Opções"
    BEGIN
        MENUITEM "&Principiante", IDM_BEGINNER
        MENUITEM "&Intermédio", IDM_INTERMEDIATE
        MENUITEM "&Perito", IDM_EXPERT
        MENUITEM "&Mestre", IDM_MASTER
        MENUITEM SEPARATOR
        MENUITEM "&Sem animação", IDM_ANIM_NONE
        MENUITEM "Animação &lenta", IDM_ANIM_SLOW
        MENUITEM "Animação &rápida", IDM_ANIM_FAST
    END
    POPUP "&Ajuda"
    BEGIN
        MENUITEM "&Conteúdo\tF1", IDM_HELP_CONTENTS
        MENUITEM "&Procurar na Ajuda...", IDM_HELP_SEARCH
        MENUITEM "&Como utilizar a Ajuda", IDM_HELP_USING
        MENUITEM SEPARATOR
        MENUITEM "&Acerca do Reversi...", IDM_ABOUT
    END
END

LANGUAGE LANG_PORTUGUESE, SUBLANG_PORTUGUESE
STRINGTABLE
BEGIN
    IDS_APP_TITLE "Reversi"
    IDS_PRACTICE_TITLE "Jogo de treino Reversi"
    IDS_PASS_TEXT "Passar"
    IDS_MUST_PASS "Não tem nenhuma casa livre onde jogar e tem de passar."
    IDS_DRAW "Empate"
    IDS_LOST_FMT "Perdeu por %d peças"
    IDS_WON_FMT "Ganhou por %d peças"
