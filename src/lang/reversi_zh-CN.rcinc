/* Included by reversi.rc. Menu and strings for zh-CN. */

LANGUAGE LANG_CHINESE, SUBLANG_CHINESE_SIMPLIFIED
IDR_MAINMENU MENU
BEGIN
    POPUP "游戏(&G)"
    BEGIN
        MENUITEM "开局(&N)\tF2", IDM_NEW
        MENUITEM SEPARATOR
        MENUITEM "让棋(&P)", IDM_PASS
        MENUITEM "提示(&H)\tBackspace", IDM_HINT
        MENUITEM SEPARATOR
        MENUITEM "退出(&X)", IDM_EXIT
    END
    POPUP "选项(&O)"
    BEGIN
        MENUITEM "初级(&B)", IDM_BEGINNER
        MENUITEM "中级(&N)", IDM_INTERMEDIATE
        MENUITEM "高级(&E)", IDM_EXPERT
        MENUITEM "大师(&M)", IDM_MASTER
        MENUITEM SEPARATOR
        MENUITEM "无动画(&D)", IDM_ANIM_NONE
        MENUITEM "慢动画(&S)", IDM_ANIM_SLOW
        MENUITEM "快动画(&F)", IDM_ANIM_FAST
    END
    POPUP "帮助(&H)"
    BEGIN
        MENUITEM "目录(&C)\tF1", IDM_HELP_CONTENTS
        MENUITEM "搜索帮助内容(&S)...", IDM_HELP_SEARCH
        MENUITEM "如何使用帮助(&H)", IDM_HELP_USING
        MENUITEM SEPARATOR
        MENUITEM "关于翻转棋(&A)...", IDM_ABOUT
    END
END

LANGUAGE LANG_CHINESE, SUBLANG_CHINESE_SIMPLIFIED
STRINGTABLE
BEGIN
    IDS_APP_TITLE "翻转棋"
    IDS_PRACTICE_TITLE "翻转棋练习赛"
