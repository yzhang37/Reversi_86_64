\par
\pard\sb45\sl-235\li295\ri125\fi-185 \tx295 \plain\f1\fs18 \{bmc bm0.bmp\}\plain\fs18 \tab \f1 \uldb Flipping pieces\plain\f1\fs18 {\v TOPIC_FLIP}\f1\fs18 : All outflanked pieces are flipped.
\par
\pard\sb45\sl-235\li295\ri125\fi-185 \tx295 \plain\f1\fs18 \{bmc bm0.bmp\}\plain\fs18 \tab \f1 If a side has no legal move, that side must pass.
\par
