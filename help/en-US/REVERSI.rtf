{\up A}{\footnote\pard\plain{\up A} a-reversi-legal}
\pard\sb115\sa35\sl-235\li115\ri125 \f1\b\fs18 Legal moves\plain\f1\fs18
\par
\pard\sb75\sl-235\li115\ri125 \plain\f1\fs18 A legal move is an empty square that outflanks at least one opposing piece.
\par
\pard\sb115\sa35\sl-235\li115\ri125 \f1\b\fs18 Steps\plain\f1\fs18
\par
\pard\sb75\sl-235\li295\ri125\fi-185 \tx295 \plain\fs18 1\tab \f1 The square must be empty.
\par
\pard\sb45\sl-235\li295\ri125\fi-185 \tx295 \plain\fs18 2\tab \f1 The new piece must outflank at least one opposing piece. (\ul outflank\plain\f1\fs18 {\v POP_OUTFLANK}\f1\fs18 )
\par
\pard\sb45\sl-235\li295\ri125\fi-185 \tx295 \plain\fs18 3\tab \f1 The outflanked pieces must be in one straight horizontal, vertical, or diagonal line.
\par
\pard\sb45\sl-235\li295\ri125\fi-185 \tx295 \plain\fs18 4\tab \f1 If the pointer becomes a cross, the square is legal.
\par
\pard\sb115\sa35\sl-235\li115\ri125 \f1\b\fs18 Related Topics\plain\f1\fs18
\par
\pard\sb35\sl-235\li115\ri125 \tx295 \f1\fs18 \{button ,AL("a-reversi-flip;a-reversi-turn")\} \uldb Related Topics\plain\f1\fs18 {\v %!AL("a-reversi-flip;a-reversi-turn")}
\par

