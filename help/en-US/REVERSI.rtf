{\up A}{\footnote\pard\plain{\up A} a-reversi-end}
\pard\sb115\sa35\sl-235\li115\ri125 \f1\b\fs18 Game end and scoring\plain\f1\fs18
\par
\pard\sb75\sl-235\li115\ri125 \plain\f1\fs18 The game ends when neither side can make another legal move.
\par
\pard\sb115\sa35\sl-235\li115\ri125 \f1\b\fs18 end condition\plain\f1\fs18
\par
\pard\sb35\sl-235\li115\ri125 \plain\f1\fs18 A game may end before every square is filled.
\par
\pard\sb115\sa35\sl-235\li115\ri125 \f1\b\fs18 scoring\plain\f1\fs18
\par
\pard\sb35\sl-235\li115\ri125 \plain\f1\fs18 When the game ends, the pieces are counted.
\par
\pard\sb115\sa35\sl-235\li115\ri125 \f1\b\fs18 winner\plain\f1\fs18
\par
\pard\sb35\sl-235\li115\ri125 \plain\f1\fs18 If your red pieces outnumber the computer's blue pieces, you win.
\par
\pard\sb115\sa35\sl-235\li115\ri125 \f1\b\fs18 Related Topics\plain\f1\fs18
\par
